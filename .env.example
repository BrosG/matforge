# ============================================
# MatForge Environment Configuration
# ============================================
# Copy this file to .env and update the values

# --- Application ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-secret-key
PROJECT_NAME=MatForge

# --- Database ---
DATABASE_URL=postgresql+psycopg2://matforge:matforge@db:5432/matforge_dev

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
WEBSOCKET_REDIS_URL=redis://redis:6379/3

# --- CORS ---
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Authentication ---
ENABLE_API_AUTHENTICATION=true
ACCESS_TOKEN_EXPIRE_DAYS=8
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-nextauth-secret

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Firebase ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=matforge-50499.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=matforge-50499
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=matforge-50499.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Prisma (frontend) ---
PRISMA_DATABASE_URL=postgresql://matforge:matforge@localhost:5433/matforge_dev?schema=app
